init

entero dfs(u: entero){
  val depth, i, n: entero; 
  depth = 0;
  i = 0;
  n = len(ajd[u]);
  esperaque(i < n) \/ {
    si(visited[i] != 1){
      depth = depth + dfs(i) + 1;
    }
  }  
  regresa depth;
};

arranca
  iteraciones = 5;

  val res: entero = dfs(0);
  dale res;

  res = res * 100 - 50;
  si (res > 10){
    dale "Mucho";
  }
  sino {
    dale "Poco";
  }
acaba
